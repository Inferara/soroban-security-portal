<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Local vendored feed for custom packages not on nuget.org (e.g. UglyToad.PdfPig 1.7.0-custom-5).
         The .nupkg lives in ./local-nuget (gitignored — must be present in the build context). -->
    <add key="local" value="./local-nuget" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
